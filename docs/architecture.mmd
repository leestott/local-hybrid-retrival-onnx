    "fontSize": "18px",
    "primaryTextColor": "#18212F",
    "lineColor": "#355070",
    "clusterBkg": "#FFFDF8",
    "clusterBorder": "#355070"
  },
  "flowchart": {
    "curve": "basis",
    "nodeSpacing": 34,
